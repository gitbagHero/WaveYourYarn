{
  "name": "waveyouryarn",
  "version": "0.2.5",
  "productName": "WaveYourYarn",
  "author": "WaveYourYarn contributors",
  "description": "A desktop tool platform for exporting, analyzing, organizing, and migrating personal music preference data.",
  "main": "out/main/index.js",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "dev:llm-check": "node --import tsx scripts/check-development-llm-connection.ts",
    "dev:llm-report": "node --experimental-sqlite --import tsx scripts/run-development-ai-report.ts",
    "dev:llm-report:dry": "node --experimental-sqlite --import tsx scripts/run-development-ai-report.ts --dry-run",
    "build": "pnpm run typecheck && electron-vite build && pnpm run verify:preload && pnpm run verify:dev-llm-boundary",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "node --experimental-sqlite ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node --experimental-sqlite ./node_modules/vitest/vitest.mjs",
    "test:e2e": "pnpm run build && pnpm run test:e2e:run",
    "test:e2e:run": "pnpm run rebuild:native && playwright test",
    "test:e2e:packaged": "node scripts/run-packaged-e2e.mjs",
    "verify:preload": "node scripts/verify-preload-build.mjs",
    "verify:dev-llm-boundary": "node scripts/verify-dev-llm-boundary.mjs",
    "verify:dev-llm-package-boundary": "node scripts/verify-dev-llm-boundary.mjs --current-package",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build",
    "package:dir": "pnpm run build && electron-builder --dir --publish never && pnpm run verify:dev-llm-package-boundary",
    "package:mac": "node scripts/package-macos.mjs",
    "icons:build": "node scripts/generate-icons.mjs",
    "format": "prettier --write .",
    "db:init": "echo \"Database is initialized automatically on app startup.\"",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@neteasecloudmusicapienhanced/api": "^4.36.1",
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^11.8.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/asar": "3.4.1",
    "@electron/rebuild": "^4.0.6",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "2.1.9"
  },
  "build": {
    "appId": "com.waveyouryarn.desktop",
    "productName": "WaveYourYarn",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "npmRebuild": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/.env",
      "!**/.env.*"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
