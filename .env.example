# Development-only OpenAI-compatible LLM configuration.
# Copy this file to .env.development.local and keep all real provider values local.
# This configuration is loaded by `pnpm dev` only and must never enter a release.
WYY_DEV_LLM_BASE_URL=
WYY_DEV_LLM_MODEL_ID=
WYY_DEV_LLM_API_KEY=
# Long report generation timeout; the fixed connection ping remains capped at 60 seconds.
WYY_DEV_LLM_TIMEOUT_MS=600000
# Optional override for the local read-only development database.
WYY_DEV_LLM_DATABASE_PATH=
